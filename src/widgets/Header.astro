---
import type { HomeContent } from "@/entities/home-content";
import { getLocalePath, LOCALE_LABELS } from "@/shared/config/site";
import type { Dictionary, Locale } from "@/shared/i18n/types";
import InlineRichText from "@/shared/ui/InlineRichText.astro";
import Logo from "@/shared/ui/Logo.astro";

interface Props {
  locale: Locale;
  dictionary: Dictionary;
  content: HomeContent;
}

const { locale, dictionary, content } = Astro.props;
const navLinks = [
  { href: "#about", label: dictionary.nav.links.about, richText: dictionary.nav.links.aboutRichText },
  { href: "#skills", label: dictionary.nav.links.skills, richText: dictionary.nav.links.skillsRichText },
  { href: "#projects", label: dictionary.nav.links.projects, richText: dictionary.nav.links.projectsRichText },
  { href: "#contact", label: dictionary.nav.links.contact, richText: dictionary.nav.links.contactRichText },
];
const locales = Object.entries(LOCALE_LABELS) as [Locale, string][];
const currentLocaleLabel = LOCALE_LABELS[locale];
---

<header id="siteHeader" class="fixed inset-x-0 top-0 z-50">
  <nav
    class="flex w-full items-center justify-between px-6 py-5 sm:px-8 lg:px-12 xl:px-16"
    aria-label={dictionary.nav.ariaLabel}
  >
    <Logo href="#hero" label={dictionary.nav.homeAriaLabel} />

    <div class="hidden items-center gap-8 md:flex">
      <ul class="flex items-center gap-8 text-sm font-semibold">
        {
          navLinks.map((item) => (
            <li>
              <a href={item.href} class="nav-link transition">
                <InlineRichText value={item.richText ?? item.label} allowLinks={false} />
              </a>
            </li>
          ))
        }
      </ul>

      <div class="locale-switcher relative" aria-label={dictionary.nav.localeAriaLabel}>
        <button
          type="button"
          class="locale-trigger inline-flex items-center gap-1.5 rounded-full px-3 py-2 text-xs font-bold transition"
          aria-label={`${dictionary.nav.localeAriaLabel}: ${currentLocaleLabel}`}
          aria-haspopup="menu"
          aria-expanded="false"
          aria-controls="desktopLocaleMenu"
          data-locale-trigger
        >
          <svg
            class="h-4 w-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="9" />
            <path d="M3 12h18" />
            <path d="M12 3c2.2 2.4 3.4 5.4 3.4 9s-1.2 6.6-3.4 9" />
            <path d="M12 3c-2.2 2.4-3.4 5.4-3.4 9s1.2 6.6 3.4 9" />
          </svg>
          <span>{currentLocaleLabel}</span>
          <svg
            class="h-3.5 w-3.5"
            viewBox="0 0 20 20"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.17l3.71-3.94a.75.75 0 1 1 1.08 1.04l-4.25 4.5a.75.75 0 0 1-1.08 0l-4.25-4.5a.75.75 0 0 1 .02-1.06Z"
              clip-rule="evenodd"
            />
          </svg>
        </button>

        <div
          id="desktopLocaleMenu"
          class="locale-menu hidden absolute right-0 top-full mt-2 w-32 rounded-lg border p-1 shadow-lg"
          role="menu"
          data-locale-menu
        >
          {
            locales.map(([item, label]) => (
              <a
                href={getLocalePath(item)}
                class:list={["locale-menu-link flex items-center justify-between rounded-md px-3 py-2 text-xs font-bold transition", item === locale ? "is-active" : undefined]}
                role="menuitem"
                aria-current={item === locale ? "page" : undefined}
              >
                <span>{label}</span>
              </a>
            ))
          }
        </div>
      </div>

      <a
        href={content.profile.githubUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="nav-cta inline-flex items-center gap-2 rounded-full border px-4 py-2 text-sm font-semibold transition"
        aria-label={dictionary.nav.githubAriaLabel}
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.6v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.3 4.6 18.3 5 18.3 5c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .4.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5Z"
          />
        </svg>
        <InlineRichText value={dictionary.nav.githubLabelRichText ?? dictionary.nav.githubLabel} allowLinks={false} />
      </a>
    </div>

    <button
      id="menuBtn"
      type="button"
      class="inline-flex h-10 w-10 items-center justify-center rounded-lg border border-slate-200 md:hidden"
      aria-label={dictionary.nav.menuOpenLabel}
      aria-expanded="false"
      aria-controls="mobileMenu"
      data-open-label={dictionary.nav.menuOpenLabel}
      data-close-label={dictionary.nav.menuCloseLabel}
    >
      <svg
        class="h-5 w-5"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        aria-hidden="true"
      >
        <path d="M3 6h18M3 12h18M3 18h18" />
      </svg>
    </button>
  </nav>

  <div id="mobileMenu" class="hidden border-t border-slate-100 bg-white/95 backdrop-blur md:hidden">
    <ul class="flex flex-col gap-1 px-6 py-4 text-sm font-semibold text-slate-700">
      {
        navLinks.map((item) => (
          <li>
            <a href={item.href} class="block rounded-lg px-3 py-2.5 hover:bg-slate-50">
              <InlineRichText value={item.richText ?? item.label} allowLinks={false} />
            </a>
          </li>
        ))
      }
      <li>
        <a
          href={content.profile.githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="block rounded-lg px-3 py-2.5 hover:bg-slate-50"
        >
          <InlineRichText value={dictionary.nav.githubLabelRichText ?? dictionary.nav.githubLabel} allowLinks={false} />
        </a>
      </li>
      <li>
        <div class="locale-switcher locale-switcher-mobile relative mt-2 px-3" aria-label={dictionary.nav.localeAriaLabel}>
          <button
            type="button"
            class="locale-trigger inline-flex w-full items-center justify-between rounded-lg px-3 py-2.5 text-xs font-bold transition"
            aria-label={`${dictionary.nav.localeAriaLabel}: ${currentLocaleLabel}`}
            aria-haspopup="menu"
            aria-expanded="false"
            aria-controls="mobileLocaleMenu"
            data-locale-trigger
          >
            <span class="inline-flex items-center gap-2">
              <svg
                class="h-4 w-4"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <circle cx="12" cy="12" r="9" />
                <path d="M3 12h18" />
                <path d="M12 3c2.2 2.4 3.4 5.4 3.4 9s-1.2 6.6-3.4 9" />
                <path d="M12 3c-2.2 2.4-3.4 5.4-3.4 9s1.2 6.6 3.4 9" />
              </svg>
              <span>{currentLocaleLabel}</span>
            </span>
            <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path
                fill-rule="evenodd"
                d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.17l3.71-3.94a.75.75 0 1 1 1.08 1.04l-4.25 4.5a.75.75 0 0 1-1.08 0l-4.25-4.5a.75.75 0 0 1 .02-1.06Z"
                clip-rule="evenodd"
              />
            </svg>
          </button>

          <div
            id="mobileLocaleMenu"
            class="locale-menu hidden mt-2 rounded-lg border p-1 shadow-lg"
            role="menu"
            data-locale-menu
          >
            {
              locales.map(([item, label]) => (
                <a
                  href={getLocalePath(item)}
                  class:list={["locale-menu-link flex items-center justify-between rounded-md px-3 py-2 text-xs font-bold transition", item === locale ? "is-active" : undefined]}
                  role="menuitem"
                  aria-current={item === locale ? "page" : undefined}
                >
                  <span>{label}</span>
                </a>
              ))
            }
          </div>
        </div>
      </li>
    </ul>
  </div>
</header>
