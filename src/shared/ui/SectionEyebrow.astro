---
import type { RichTextValue } from "@/shared/rich-text/types";
import InlineRichText from "./InlineRichText.astro";

interface Props {
  label: string;
  richText?: RichTextValue;
  tone?: "light" | "dark";
}

const { label, richText, tone = "light" } = Astro.props;
const lineClass = tone === "dark" ? "bg-brand-500" : "bg-brand-600";
const textClass = tone === "dark" ? "text-brand-500" : "text-brand-600";
---

<div class="flex items-center gap-3">
  <span class:list={["h-px w-10", lineClass]}></span>
  <span class:list={["text-sm font-bold uppercase tracking-[0.2em]", textClass]}>
    <InlineRichText value={richText ?? label} allowLinks={false} />
  </span>
</div>
