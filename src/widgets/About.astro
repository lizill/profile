---
import type { HomeContent } from "@/entities/home-content";
import type { Dictionary, Locale } from "@/shared/i18n/types";
import CareerYear from "@/shared/ui/CareerYear.astro";
import InlineRichText from "@/shared/ui/InlineRichText.astro";
import SectionEyebrow from "@/shared/ui/SectionEyebrow.astro";

interface Props {
  locale: Locale;
  dictionary: Dictionary;
  content: HomeContent;
}

const { locale, dictionary, content } = Astro.props;
const { profile } = content;
---

<section id="about" class="mx-auto max-w-7xl px-6 py-24 sm:px-10 lg:px-16">
  <div class="reveal">
    <SectionEyebrow label={dictionary.sections.about.eyebrow} richText={dictionary.sections.about.eyebrowRichText} />
    <h2 class="mt-4 font-display text-3xl font-extrabold tracking-tight sm:text-4xl">
      <InlineRichText value={dictionary.sections.about.titleRichText ?? dictionary.sections.about.title} allowLinks={false} />
    </h2>
  </div>

  <div class="mt-12 grid grid-cols-1 gap-12 lg:grid-cols-5">
    <div class="reveal lg:col-span-3">
      <p class="break-keep text-lg leading-relaxed text-slate-600">
        <InlineRichText value={profile.aboutTextRichText ?? profile.aboutText} />
      </p>
    </div>

    <ul class="reveal grid grid-cols-2 gap-4 lg:col-span-2">
      <li class="rounded-2xl bg-slate-50 p-5">
        <div class="font-display text-3xl font-extrabold text-brand-600">
          <CareerYear locale={locale} startDate={profile.careerStartDate} /><InlineRichText value={profile.careerYearUnitRichText ?? profile.careerYearUnit} allowLinks={false} />
        </div>
        <div class="mt-1 text-sm font-medium text-slate-500">
          <InlineRichText value={profile.experienceLabelRichText ?? profile.experienceLabel} allowLinks={false} />
        </div>
      </li>
      <li class="rounded-2xl bg-slate-50 p-5">
        <div class="font-display text-3xl font-extrabold text-brand-600">
          <InlineRichText value={profile.companyRichText ?? profile.company} allowLinks={false} />
        </div>
        <div class="mt-1 text-sm font-medium text-slate-500">
          <InlineRichText value={profile.teamLabelRichText ?? profile.teamLabel} allowLinks={false} />
        </div>
      </li>
      <li class="col-span-2 rounded-2xl bg-slate-50 p-5">
        <div class="text-sm font-semibold text-slate-700">
          <InlineRichText value={profile.phaseLabelRichText ?? profile.phaseLabel} allowLinks={false} />
        </div>
        <div class="mt-3 flex flex-wrap gap-2">
          {
            profile.phases.map((phase) => (
              <span class="rounded-full bg-white px-3 py-1 text-xs font-semibold text-slate-600 ring-1 ring-slate-200">
                {phase}
              </span>
            ))
          }
        </div>
      </li>
    </ul>
  </div>
</section>
