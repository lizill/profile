---
import type { HomeContent } from "@/entities/home-content";
import CareerYear from "@/shared/ui/CareerYear.astro";
import type { Dictionary, Locale } from "@/shared/i18n/types";
import InlineRichText from "@/shared/ui/InlineRichText.astro";

interface Props {
  locale: Locale;
  dictionary: Dictionary;
  content: HomeContent;
}

const { locale, dictionary, content } = Astro.props;
const { profile } = content;
---

<section id="hero" class="relative grid min-h-screen grid-cols-1 lg:grid-cols-2">
  <div class="relative z-10 flex flex-col justify-center px-6 py-24 sm:px-10 lg:px-16">
    <div class="flex items-center gap-3">
      <span class="h-px w-12 bg-brand-600"></span>
      <span class="text-sm font-bold uppercase tracking-[0.2em] text-brand-600">
        <InlineRichText value={profile.romanNameRichText ?? profile.romanName} allowLinks={false} />
      </span>
    </div>

    <h1 class="mt-6 font-display text-4xl font-extrabold leading-[1.1] tracking-tight sm:text-5xl lg:text-6xl">
      <InlineRichText value={dictionary.hero.titleLine1RichText ?? dictionary.hero.titleLine1} allowLinks={false} /><br />
      <InlineRichText value={dictionary.hero.titleLine2RichText ?? dictionary.hero.titleLine2} allowLinks={false} /><br />
      <span class="text-brand-600">
        <InlineRichText value={profile.displayNameRichText ?? profile.displayName} allowLinks={false} />
      </span><InlineRichText value={dictionary.hero.titleSuffixRichText ?? dictionary.hero.titleSuffix} allowLinks={false} />
    </h1>

    <p class="mt-6 max-w-lg break-keep text-base leading-relaxed text-slate-500 sm:text-lg">
      <InlineRichText value={profile.summaryBeforeCareerRichText ?? profile.summaryBeforeCareer} boldClass="font-semibold text-ink" />
      <span class="font-semibold text-brand-600">
        <CareerYear locale={locale} startDate={profile.careerStartDate} /><InlineRichText value={profile.careerYearUnitRichText ?? profile.careerYearUnit} allowLinks={false} />
      </span>
      <InlineRichText value={profile.summaryAfterCareerRichText ?? profile.summaryAfterCareer} boldClass="font-semibold text-ink" />
    </p>

    <div class="mt-9 flex flex-wrap items-center gap-4">
      <a
        href="#projects"
        class="inline-flex items-center gap-2 rounded-full bg-brand-600 px-7 py-3.5 text-sm font-bold text-white shadow-lg shadow-brand-600/25 transition hover:bg-brand-700"
      >
        <InlineRichText value={dictionary.hero.primaryCtaRichText ?? dictionary.hero.primaryCta} allowLinks={false} />
        <svg
          class="h-4 w-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path d="M5 12h14M13 6l6 6-6 6" />
        </svg>
      </a>
      <a
        href="#contact"
        class="inline-flex items-center gap-2 rounded-full border border-slate-300 px-7 py-3.5 text-sm font-bold text-slate-700 transition hover:border-brand-600 hover:text-brand-600"
      >
        <InlineRichText value={dictionary.hero.secondaryCtaRichText ?? dictionary.hero.secondaryCta} allowLinks={false} />
      </a>
    </div>

    <a
      href="#about"
      class="absolute bottom-8 left-1/2 flex h-12 w-12 -translate-x-1/2 items-center justify-center rounded-full border border-slate-200 text-slate-400 transition hover:border-brand-600 hover:text-brand-600"
      aria-label={dictionary.hero.scrollAriaLabel}
    >
      <svg
        class="bob h-4 w-4"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        aria-hidden="true"
      >
        <path d="M12 5v14M6 13l6 6 6-6" />
      </svg>
    </a>
  </div>

  <div
    class="relative min-h-[40vh] overflow-hidden bg-gradient-to-br from-brand-600 via-indigo-600 to-violet-700 lg:min-h-screen"
    aria-hidden="true"
  >
    <div
      class="absolute inset-0 opacity-30"
      style="background-image: radial-gradient(circle at 28% 28%, rgba(255, 255, 255, 0.35), transparent 45%);"
    >
    </div>
    <div
      class="absolute inset-0 opacity-20"
      style="background-image: radial-gradient(circle at 78% 76%, rgba(255, 255, 255, 0.3), transparent 42%);"
    >
    </div>

    <div class="anim-spin absolute left-1/2 top-1/2 h-72 w-72 -translate-x-1/2 -translate-y-1/2 rounded-[2.5rem] border-2 border-white/20"></div>
    <div class="absolute left-1/2 top-1/2 h-[26rem] w-[26rem] -translate-x-1/2 -translate-y-1/2 rounded-full border border-white/10"></div>

    <div class="anim-a absolute left-[30%] top-[24%] h-24 w-24 rounded-3xl bg-pink-300/90 shadow-2xl"></div>
    <div class="anim-b absolute right-[28%] top-[28%] h-20 w-20 rounded-2xl bg-amber-400 shadow-2xl"></div>
    <div class="anim-c absolute bottom-[28%] left-[31%] h-16 w-16 rounded-full bg-sky-300 shadow-2xl"></div>
    <div class="anim-a absolute bottom-[26%] right-[30%] h-14 w-14 rounded-full bg-white/90 shadow-2xl"></div>
    <div class="anim-b absolute left-[47%] top-[19%] h-10 w-10 rotate-45 rounded-lg bg-white/30"></div>

    <div class="anim-c absolute right-[14%] top-[15%] h-9 w-9 rounded-full border-2 border-white/25"></div>
    <div class="anim-b absolute bottom-[16%] left-[15%] h-11 w-11 rotate-12 rounded-xl bg-white/15"></div>
    <div class="anim-a absolute bottom-[36%] right-[17%] h-7 w-7 rounded-md bg-amber-300/70 shadow-lg"></div>
    <span class="absolute left-[18%] top-[44%] h-2.5 w-2.5 rounded-full bg-white/50"></span>
    <span class="absolute right-[21%] top-[66%] h-2 w-2 rounded-full bg-white/50"></span>
    <span class="absolute left-[42%] top-[13%] h-1.5 w-1.5 rounded-full bg-white/60"></span>
    <span class="absolute right-[42%] bottom-[15%] h-2 w-2 rounded-full bg-white/40"></span>

    <div class="anim-c absolute left-1/2 top-1/2 flex h-40 w-40 -translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-3xl bg-white/10 backdrop-blur-sm ring-1 ring-white/30">
      <span class="font-display text-6xl font-extrabold leading-none text-white/90 -translate-y-[0.12em]">
        &lt;/&gt;
      </span>
    </div>
  </div>
</section>
